{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter @wjptz/suncode-core build && pnpm --filter @wjptz/suncode build",
    "build:core": "pnpm --filter @wjptz/suncode-core build",
    "build:cli": "pnpm --filter @wjptz/suncode build",
    "test": "pnpm --filter @wjptz/suncode-core test && pnpm --filter @wjptz/suncode test",
    "test:core": "pnpm --filter @wjptz/suncode-core test",
    "test:cli": "pnpm --filter @wjptz/suncode test",
    "lint": "pnpm --filter @wjptz/suncode-core lint && pnpm --filter @wjptz/suncode lint",
    "typecheck": "pnpm --filter @wjptz/suncode-core build && pnpm --filter @wjptz/suncode typecheck",
    "release": "pnpm --filter @wjptz/suncode release",
    "release:minor": "pnpm --filter @wjptz/suncode release:minor",
    "release:major": "pnpm --filter @wjptz/suncode release:major",
    "release:beta": "pnpm --filter @wjptz/suncode release:beta",
    "release:rc": "pnpm --filter @wjptz/suncode release:rc",
    "release:promote": "pnpm --filter @wjptz/suncode release:promote",
    "release:check": "node packages/cli/scripts/release-preflight.js check-versions",
    "release:plan": "node packages/cli/scripts/release-preflight.js publish-plan"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
